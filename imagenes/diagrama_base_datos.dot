ion</FONT></TD></TR><TR><TD BGCOLOR="#F3F4F6" ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="#1C1917"><B>times_retrieved</B></FONT></TD><TD BGCOLOR="#F3F4F6" ALIGN="LEFT"><FONT POINT-SIZE="7.5" COLOR="#6D28D9"><I>int</I></FONT></TD><TD BGCOLOR="#F3F4F6" ALIGN="LEFT"><FONT POINT-SIZE="7" COLOR="#6B7280">RAG usage frequency counter</FONT></TD></TR><TR><TD BGCOLOR="#FAFAFA" ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="#1C1917"><B>answer_length_tokens</B></FONT></TD><TD BGCOLOR="#FAFAFA" ALIGN="LEFT"><FONT POINT-SIZE="7.5" COLOR="#6D28D9"><I>int</I></FONT></TD><TD BGCOLOR="#FAFAFA" ALIGN="LEFT"><FONT POINT-SIZE="7" COLOR="#6B7280">context budget control</FONT></TD></TR><TR><TD BGCOLOR="#EDE9FE" ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="#5B21B6">&#9670; <B>embedding</B></FONT></TD><TD BGCOLOR="#EDE9FE" ALIGN="LEFT"><FONT POINT-SIZE="7.5" COLOR="#6D28D9"><I>F32_BLOB</I></FONT></TD><TD BGCOLOR="#EDE9FE" ALIGN="LEFT"><FONT POINT-SIZE="7" COLOR="#6B7280">1536-dim · cosine vector search</FONT></TD></TR><TR><TD BGCOLOR="#FAFAFA" ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="#1C1917"><B>created_at</B></FONT></TD><TD BGCOLOR="#FAFAFA" ALIGN="LEFT"><FONT POINT-SIZE="7.5" COLOR="#6D28D9"><I>text</I></FONT></TD><TD BGCOLOR="#FAFAFA" ALIGN="LEFT"><FONT POINT-SIZE="7" COLOR="#6B7280">CURRENT_TIMESTAMP</FONT></TD></TR><TR><TD BGCOLOR="#F3F4F6" ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="#1C1917"><B>reviewed_at</B></FONT></TD><TD BGCOLOR="#F3F4F6" ALIGN="LEFT"><FONT POINT-SIZE="7.5" COLOR="#6D28D9"><I>text</I></FONT></TD><TD BGCOLOR="#F3F4F6" ALIGN="LEFT"><FONT POINT-SIZE="7" COLOR="#6B7280">HITL review timestamp</FONT></TD></TR></TABLE>>]
